model PurchasedIdea {
    id        String   @id @default(uuid())
    userId    String
    ideaId    String
    user      User     @relation(fields: [userId], references: [id])
    idea      Idea     @relation(fields: [ideaId], references: [id])
    createdAt DateTime @default(now())

    @@unique([userId, ideaId])
}
